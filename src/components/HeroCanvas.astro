---
// Interactive animated neural-network background for the hero.
---
<canvas
  id="hero-canvas"
  class="pointer-events-none absolute inset-0 h-full w-full"
  aria-hidden="true"
></canvas>

<script>
  const init = () => {
    const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    type Node = { x: number; y: number; vx: number; vy: number };
    let nodes: Node[] = [];
    let raf = 0;
    let width = 0;
    let height = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const mouse = { x: -9999, y: -9999 };

    const parent = canvas.parentElement as HTMLElement;

    const resize = () => {
      const rect = parent.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const density = Math.min(90, Math.floor((width * height) / 14000));
      nodes = Array.from({ length: density }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
      }));
    };

    const draw = () => {
      ctx.clearRect(0, 0, width, height);
      const LINK = 130;
      // Emerald reads fine on both themes; use a bit more contrast on light.
      const isDark = document.documentElement.classList.contains("dark");
      const lineRGB = isDark ? "52, 211, 153" : "5, 150, 105";
      const nodeBase = isDark ? "rgba(52, 211, 153, 0.55)" : "rgba(5, 150, 105, 0.6)";
      const nodeHot = isDark ? "rgba(110, 231, 183, 0.95)" : "rgba(4, 120, 87, 0.95)";
      const lineAlphaScale = isDark ? 0.5 : 0.6;

      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > width) n.vx *= -1;
        if (n.y < 0 || n.y > height) n.vy *= -1;

        // gentle pull toward cursor
        const dxm = mouse.x - n.x;
        const dym = mouse.y - n.y;
        const dm = Math.hypot(dxm, dym);
        if (dm < 160) {
          n.x += (dxm / dm) * 0.5;
          n.y += (dym / dm) * 0.5;
        }

        for (let j = i + 1; j < nodes.length; j++) {
          const m = nodes[j];
          const dx = n.x - m.x;
          const dy = n.y - m.y;
          const dist = Math.hypot(dx, dy);
          if (dist < LINK) {
            const alpha = (1 - dist / LINK) * lineAlphaScale;
            ctx.strokeStyle = `rgba(${lineRGB}, ${alpha})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(n.x, n.y);
            ctx.lineTo(m.x, m.y);
            ctx.stroke();
          }
        }

        const nearMouse = dm < 160;
        ctx.fillStyle = nearMouse ? nodeHot : nodeBase;
        ctx.beginPath();
        ctx.arc(n.x, n.y, nearMouse ? 2.6 : 1.7, 0, Math.PI * 2);
        ctx.fill();
      }

      raf = requestAnimationFrame(draw);
    };

    resize();
    if (reduced) {
      draw();
      cancelAnimationFrame(raf); // one static frame only
    } else {
      draw();
    }

    window.addEventListener("resize", resize);
    parent.addEventListener("pointermove", (e) => {
      const rect = parent.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    parent.addEventListener("pointerleave", () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });
  };

  init();
  document.addEventListener("astro:page-load", init);
</script>
