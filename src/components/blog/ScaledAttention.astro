  }
  .saa-tri-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 6px;
    margin-bottom: 6px;
  }
  .saa-tri-name {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text);
  }
  .saa-tri-verdict {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .saa-tri-verdict.safe { color: var(--teal); }
  .saa-tri-verdict.warn { color: var(--red); }
  .saa-tri-foot {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    margin-top: 8px;
    text-align: center;
  }
  .saa-led-mini { margin-top: 10px; gap: 6px; }
  .saa-led-mini .saa-led-strip { height: 60px; width: 12px; }
  .saa-led-mini .saa-led-name { font-size: 9px; }
  .saa-led-mini .saa-led-pct { font-size: 9px; }
  .saa-led-mini .saa-led-channel.query::before { display: none; }

  @media (max-width: 560px) {
    .saa-triptych { grid-template-columns: 1fr; }
  }

  /* ---------- math block ---------- */
  .saa-math {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px 20px;
    margin: 18px 0;
    overflow-x: auto;
  }
  .saa .katex {
    color: var(--text) !important;
    font-size: 1.02em;
  }

  /* ---------- footer ---------- */
  .saa-footer {
    padding-top: 80px;
    padding-bottom: 100px;
    border-top: 1px solid var(--border);
  }
  .saa-credits { margin-top: 24px; }
  .saa-credits dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 20px;
    font-size: 14px;
  }
  .saa-credits dt {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-top: 2px;
  }
  .saa-credits dd { margin: 0; color: var(--text-dim); }
  .saa-foot-note {
    margin-top: 48px;
    font-size: 13px;
    color: var(--text-faint);
  }

  @media (max-width: 640px) {
    .saa-channels { grid-template-columns: 1fr; }
    .saa-led-bank { gap: 6px; }
    .saa-led-strip { width: 16px; }
    .saa-header { padding-top: 80px; padding-bottom: 60px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .saa * {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>

<script is:inline>
  (function () {
    /* ---------- scroll progress ---------- */
    var bar = document.getElementById("saaProgress");
    function updateProgress() {
      var h = document.documentElement;
      var scrolled = h.scrollTop;
      var max = h.scrollHeight - h.clientHeight;
      var pct = max > 0 ? (scrolled / max) * 100 : 0;
      if (bar) bar.style.width = pct + "%";
    }
    document.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();

    /* ---------- reveal on scroll ---------- */
    var items = document.querySelectorAll(".saa-reveal");
    if (!("IntersectionObserver" in window)) {
      items.forEach(function (el) { el.classList.add("in-view"); });
    } else {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("in-view");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      items.forEach(function (el) { io.observe(el); });
    }

    /* ---------- shared math helpers ---------- */
    var D_OPTIONS = [4, 8, 16, 32, 64, 128, 256, 512, 1024];
    var BASE_D = 64;
    var TOKENS = ["the", "cat", "sat", "on", "mat"];
    var PRESETS = [
      { name: "sat → mat", raw: [8, 3, 12, -5, 1], queryIdx: 2 },
      { name: "on → mat", raw: [1, -2, 4, 9, 3], queryIdx: 3 },
    ];
    var SEG_COUNT = 8;

    function softmax(arr) {
      var m = Math.max.apply(null, arr);
      var exps = arr.map(function (x) { return Math.exp(x - m); });
      var sum = exps.reduce(function (a, b) { return a + b; }, 0);
      return exps.map(function (e) { return e / sum; });
    }
    function stdDev(arr) {
      var mean = arr.reduce(function (a, b) { return a + b; }, 0) / arr.length;
      var variance =
        arr.reduce(function (a, b) { return a + (b - mean) * (b - mean); }, 0) / arr.length;
      return Math.sqrt(variance);
    }
    function computeLogits(raw, d) {
      var scaleFactor = Math.sqrt(d / BASE_D);
      var unscaled = raw.map(function (r) { return r * scaleFactor; });
      var scaled = raw.map(function (r) { return (r * scaleFactor) / Math.sqrt(d); });
      return { unscaled: unscaled, scaled: scaled };
    }
    function segClass(segIndex) {
      if (segIndex >= 6) return "lit-red";
      if (segIndex >= 4) return "lit-amber";
      return "lit-teal";
    }
    function renderLedBank(containerEl, weights, queryIdx) {
      containerEl.innerHTML = "";
      weights.forEach(function (w, i) {
        var lit = Math.round(w * SEG_COUNT);
        var col = document.createElement("div");
        col.className = "saa-led-channel" + (i === queryIdx ? " query" : "");
        var strip = document.createElement("div");
        strip.className = "saa-led-strip";
        for (var s = 0; s < SEG_COUNT; s++) {
          var seg = document.createElement("div");
          seg.className = "saa-led-seg" + (s < lit ? " " + segClass(s) : "");
          strip.appendChild(seg);
        }
        var name = document.createElement("div");
        name.className = "saa-led-name";
        name.textContent = TOKENS[i];
        var pct = document.createElement("div");
        pct.className = "saa-led-pct";
        pct.textContent = Math.round(w * 100) + "%";
        col.appendChild(strip);
        col.appendChild(name);
        col.appendChild(pct);
        containerEl.appendChild(col);
      });
    }
    function updateGauge(markerEl, std, maxStd) {
      var pct = Math.min(Math.max(std / maxStd, 0), 1) * 100;
      markerEl.style.left = pct + "%";
    }

    /* ---------- Track 2: variance builder ---------- */
    (function () {
      var slider = document.getElementById("saa-t2-slider");
      var dval = document.getElementById("saa-t2-dval");
      var varEl = document.getElementById("saa-t2-var");
      var stdEl = document.getElementById("saa-t2-std");
      var blocks = document.getElementById("saa-t2-blocks");
      var CAP = 64;
      if (!slider) return;

      function render() {
        var d = D_OPTIONS[parseInt(slider.value, 10)];
        dval.textContent = d;
        varEl.textContent = d;
        stdEl.textContent = Math.sqrt(d).toFixed(2);
        blocks.innerHTML = "";
        var shown = Math.min(d, CAP);
        for (var i = 0; i < shown; i++) {
          var b = document.createElement("div");
          b.className = "saa-unit-block";
          blocks.appendChild(b);
        }
        if (d > CAP) {
          var more = document.createElement("span");
          more.className = "saa-block-more";
          more.textContent = "+ " + (d - CAP) + " more channels";
          blocks.appendChild(more);
        }
      }
      slider.addEventListener("input", render);
      render();
    })();

    /* ---------- generic softmax-bus wiring for tracks 3/4/5 ---------- */
    function wireBus(prefix, opts) {
      opts = opts || {};
      var hasAgc = !!opts.hasAgc;
      var slider = document.getElementById(prefix + "-slider");
      if (!slider) return;
      var dval = document.getElementById(prefix + "-dval");
      var ledBank = document.getElementById(prefix + "-leds");
      var stdEl = document.getElementById(prefix + "-std");
      var maxEl = document.getElementById(prefix + "-max");
      var gradEl = document.getElementById(prefix + "-grad");
      var marker = document.getElementById(prefix + "-marker");
      var presetBtns = document.querySelectorAll("#" + prefix + "-presets .saa-pill");
      var agcCheckbox = hasAgc ? document.getElementById(prefix + "-agc") : null;
      var agcLed = hasAgc ? document.getElementById(prefix + "-led") : null;
      var presetIdx = 0;
      var MAX_STD = 25;

      function render() {
        var d = D_OPTIONS[parseInt(slider.value, 10)];
        dval.textContent = d;
        var preset = PRESETS[presetIdx];
        var logits = computeLogits(preset.raw, d);
        var useScaled = hasAgc ? agcCheckbox.checked : false;
        var active = useScaled ? logits.scaled : logits.unscaled;
        var weights = softmax(active);
        var std = stdDev(active);
        var maxW = Math.max.apply(null, weights);

        renderLedBank(ledBank, weights, preset.queryIdx);
        stdEl.textContent = std.toFixed(2);
        maxEl.textContent = Math.round(maxW * 100) + "%";
        maxEl.className = "saa-value" + (maxW > 0.85 ? " warn" : maxW < 0.5 ? " safe" : "");
        gradEl.textContent = (maxW * (1 - maxW)).toFixed(3);
        updateGauge(marker, std, MAX_STD);

        if (hasAgc && agcLed) {
          agcLed.classList.toggle("on", agcCheckbox.checked);
        }
      }

      slider.addEventListener("input", render);
      presetBtns.forEach(function (btn) {
        btn.addEventListener("click", function () {
          presetBtns.forEach(function (b) { b.classList.remove("active"); });
          btn.classList.add("active");
          presetIdx = parseInt(btn.getAttribute("data-preset"), 10);
          render();
        });
      });
      if (hasAgc) agcCheckbox.addEventListener("change", render);

      render();
    }

    wireBus("saa-t3", { hasAgc: false });
    wireBus("saa-t4", { hasAgc: true });
    wireBus("saa-t5", { hasAgc: true });

    /* ---------- Track 03: Monte Carlo bench ---------- */
    (function () {
      var slider = document.getElementById("saa-mc-slider");
      if (!slider) return;
      var dval = document.getElementById("saa-mc-dval");
      var hist = document.getElementById("saa-mc-hist");
      var nEl = document.getElementById("saa-mc-n");
      var mStdEl = document.getElementById("saa-mc-mstd");
      var tStdEl = document.getElementById("saa-mc-tstd");
      var mVarEl = document.getElementById("saa-mc-mvar");
      var tVarEl = document.getElementById("saa-mc-tvar");
      var runBtn = document.getElementById("saa-mc-run");
      var resetBtn = document.getElementById("saa-mc-reset");

      var MC_D = [4, 16, 64, 256];
      var BINS = 41;
      var RANGE = 40; // fixed axis, so widening is visible
      var BIN_W = (2 * RANGE) / BINS;
      var BATCH = 3000;

      var bars = [];
      for (var b = 0; b < BINS; b++) {
        var bar = document.createElement("div");
        bar.className = "saa-hist-bin";
        bar.style.height = "0%";
        hist.appendChild(bar);
        bars.push(bar);
      }

      var counts, n, sum, sumSq;
      function reset() {
        counts = new Array(BINS).fill(0);
        n = 0;
        sum = 0;
        sumSq = 0;
      }

      // Box-Muller standard normal.
      var spare = null;
      function gauss() {
        if (spare !== null) {
          var v = spare;
          spare = null;
          return v;
        }
        var u1 = Math.random() || 1e-9;
        var u2 = Math.random();
        var mag = Math.sqrt(-2 * Math.log(u1));
        spare = mag * Math.sin(2 * Math.PI * u2);
        return mag * Math.cos(2 * Math.PI * u2);
      }

      function drawBatch(d, count) {
        for (var s = 0; s < count; s++) {
          var dot = 0;
          for (var i = 0; i < d; i++) dot += gauss() * gauss();
          sum += dot;
          sumSq += dot * dot;
          n++;
          var idx = Math.floor((dot + RANGE) / BIN_W);
          if (idx < 0) idx = 0;
          if (idx >= BINS) idx = BINS - 1;
          counts[idx]++;
        }
      }

      function render() {
        var max = 1;
        for (var i = 0; i < BINS; i++) if (counts[i] > max) max = counts[i];
        for (var j = 0; j < BINS; j++) {
          bars[j].style.height = ((counts[j] / max) * 100).toFixed(1) + "%";
        }
        nEl.textContent = n.toLocaleString() + " samples";
        if (n > 1) {
          var mean = sum / n;
          var variance = sumSq / n - mean * mean;
          if (variance < 0) variance = 0;
          mStdEl.textContent = Math.sqrt(variance).toFixed(2);
          mVarEl.textContent = variance.toFixed(1);
        } else {
          mStdEl.textContent = "0.00";
          mVarEl.textContent = "0.0";
        }
      }

      function setDim(newRun) {
        var d = MC_D[parseInt(slider.value, 10)];
        dval.textContent = d;
        tStdEl.textContent = Math.sqrt(d).toFixed(2);
        tVarEl.textContent = d;
        reset();
        if (newRun) drawBatch(d, BATCH);
        render();
      }

      slider.addEventListener("input", function () { setDim(true); });
      runBtn.addEventListener("click", function () {
        drawBatch(MC_D[parseInt(slider.value, 10)], BATCH);
        render();
      });
      resetBtn.addEventListener("click", function () { setDim(false); });

      setDim(true);
    })();

    /* ---------- Track 06: why the square root (three divisors) ---------- */
    (function () {
      var slider = document.getElementById("saa-cmp-slider");
      if (!slider) return;
      var dval = document.getElementById("saa-cmp-dval");
      var preset = PRESETS[0];

      var banks = [
        { leds: "saa-cmp-a-leds", std: "saa-cmp-a-std", v: "saa-cmp-a-v", div: function () { return 1; } },
        { leds: "saa-cmp-b-leds", std: "saa-cmp-b-std", v: "saa-cmp-b-v", div: function (d) { return Math.sqrt(d); } },
        { leds: "saa-cmp-c-leds", std: "saa-cmp-c-std", v: "saa-cmp-c-v", div: function (d) { return d; } },
      ];

      function verdictFor(maxW) {
        if (maxW >= 0.8) return { t: "clips", c: "warn" };
        if (maxW <= 0.24) return { t: "washed out", c: "warn" };
        return { t: "balanced", c: "safe" };
      }

      function render() {
        var d = D_OPTIONS[parseInt(slider.value, 10)];
        dval.textContent = d;
        var scaleFactor = Math.sqrt(d / BASE_D);
        banks.forEach(function (bank) {
          var divisor = bank.div(d);
          var logits = preset.raw.map(function (r) { return (r * scaleFactor) / divisor; });
          var weights = softmax(logits);
          var maxW = Math.max.apply(null, weights);
          renderLedBank(document.getElementById(bank.leds), weights, preset.queryIdx);
          document.getElementById(bank.std).textContent = stdDev(logits).toFixed(2);
          var verdict = verdictFor(maxW);
          var vEl = document.getElementById(bank.v);
          vEl.textContent = verdict.t;
          vEl.className = "saa-tri-verdict " + verdict.c;
        });
      }

      slider.addEventListener("input", render);
      render();
    })();
  })();
</script>
