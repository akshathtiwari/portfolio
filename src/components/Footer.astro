---
import { site } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 dark:border-white/10">
  <div class="mx-auto flex max-w-5xl flex-col gap-3 px-6 py-10 text-sm text-neutral-500 sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {year} {site.name}. Built with Astro.</p>
    <div class="flex gap-5">
      <a href={`mailto:${site.email}`} class="hover:text-neutral-900 dark:hover:text-neutral-200">Email</a>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 dark:hover:text-neutral-200">LinkedIn</a>
      <a href={site.github} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 dark:hover:text-neutral-200">GitHub</a>
      <a href={site.youtube} target="_blank" rel="noopener noreferrer" class="hover:text-neutral-900 dark:hover:text-neutral-200">YouTube</a>
    </div>
  </div>
</footer>
