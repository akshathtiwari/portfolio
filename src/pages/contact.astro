---
import Layout from "../layouts/Layout.astro";
import { site } from "../lib/site";

const links = [
  { label: "Email", value: site.email, href: `mailto:${site.email}` },
  { label: "LinkedIn", value: "akshathtiwari", href: site.linkedin },
  { label: "GitHub", value: "View profile", href: site.github },
  { label: "YouTube", value: "View channel", href: site.youtube },
];
---

<Layout title="Contact — Akshath Tiwari" description="Get in touch with Akshath Tiwari.">
  <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">Get in Touch</h1>
    <p class="mt-3 max-w-xl text-neutral-600 dark:text-neutral-400">
      Based in {site.location}. Open to conversations about LLM fine-tuning, agentic systems,
      and ML infrastructure — reach out on any of these.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith("mailto:") ? undefined : "_blank"}
          rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
          class="group rounded-lg border border-neutral-200 bg-neutral-50 p-5 transition hover:border-emerald-500/40 hover:bg-neutral-100 dark:border-white/10 dark:bg-white/[0.02] dark:hover:border-emerald-400/40 dark:hover:bg-white/[0.04]"
        >
          <p class="font-mono text-xs uppercase tracking-wide text-neutral-500">{link.label}</p>
          <p class="mt-1.5 text-sm font-medium text-neutral-900 group-hover:text-emerald-600 dark:text-neutral-100 dark:group-hover:text-emerald-300">{link.value}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
