---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Layout title="Blog — Akshath Tiwari" description="Writeups on LLM fine-tuning, agents, and evaluation.">
  <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <h1 class="text-3xl font-bold tracking-tight text-neutral-50">Blog</h1>
    <p class="mt-3 text-neutral-400">Notes on fine-tuning, agents, evaluation, and everything in between.</p>

    {posts.length === 0 && (
      <p class="mt-12 text-sm text-neutral-500">No posts yet — check back soon.</p>
    )}

    <div class="mt-10 space-y-8">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="group block">
          <p class="font-mono text-xs text-neutral-500">{formatDate(post.data.date)}</p>
          <h2 class="mt-1 text-lg font-semibold text-neutral-100 group-hover:text-emerald-300">
            {post.data.title}
          </h2>
          <p class="mt-1.5 text-sm leading-relaxed text-neutral-400">{post.data.description}</p>
          <div class="mt-2 flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <span class="rounded-full border border-white/10 px-2.5 py-0.5 text-[11px] text-neutral-500">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
