---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { site } from "../lib/site";

const allProjects = await getCollection("projects");
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const skillGroups = [
  {
    label: "LLMs & Agentic Systems",
    items: [
      "LLM Fine-Tuning (SFT & RL)",
      "LangChain / LangGraph",
      "Agentic RAG & Tool Calling",
      "Multi-Agent Orchestration",
      "LLM-as-Judge Evaluation",
    ],
  },
  {
    label: "Search, Retrieval & Data",
    items: [
      "FAISS / Qdrant / Pinecone",
      "Hybrid Retrieval (BM25 + Embeddings)",
      "Re-ranking Models",
      "Golden Datasets & Offline Eval",
    ],
  },
  {
    label: "Backend & Infra",
    items: [
      "Python (FastAPI)",
      "Microservices",
      "Docker / Kubernetes",
      "Observability-First Design",
    ],
  },
  {
    label: "ML & DL",
    items: [
      "Supervised Learning & Embeddings",
      "Ranking / Learning-to-Rank",
      "Model Evaluation & Calibration",
      "Experimentation Frameworks",
    ],
  },
];
---

<Layout>
  <section class="mx-auto max-w-5xl px-6 pb-16 pt-20 sm:pt-28">
    <p class="font-mono text-sm text-emerald-400">Hi, I'm</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-neutral-50 sm:text-6xl">
      {site.name}
    </h1>
    <h2 class="mt-3 text-xl text-neutral-400 sm:text-2xl">{site.role}</h2>
    <p class="mt-6 max-w-2xl text-base leading-relaxed text-neutral-400 sm:text-lg">
      I take messy, ambiguous problems and turn them into production-grade AI systems that
      ship — end to end, from data and evaluation design to fine-tuning, agent orchestration,
      and backend integration. Currently {site.currentRole.title} at {site.currentRole.company}.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/projects"
        class="rounded-md bg-emerald-500 px-5 py-2.5 text-sm font-medium text-neutral-950 transition hover:bg-emerald-400"
      >
        View Projects
      </a>
      <a
        href="/contact"
        class="rounded-md border border-white/15 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:border-white/30"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-14">
    <div class="flex items-baseline justify-between">
      <h3 class="text-lg font-semibold text-neutral-100">Featured Work</h3>
      <a href="/projects" class="text-sm text-emerald-400 hover:text-emerald-300">All projects &rarr;</a>
    </div>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      {featured.map((project) => (
        <a
          href={`/projects/${project.id}`}
          class="group rounded-lg border border-white/10 bg-white/[0.02] p-5 transition hover:border-emerald-400/40 hover:bg-white/[0.04]"
        >
          <p class="font-mono text-xs uppercase tracking-wide text-emerald-400/80">{project.data.theme}</p>
          <h4 class="mt-2 text-sm font-semibold text-neutral-100 group-hover:text-emerald-300">
            {project.data.title}
          </h4>
          <p class="mt-2 text-sm leading-relaxed text-neutral-500 line-clamp-3">
            {project.data.summary}
          </p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-14">
    <h3 class="text-lg font-semibold text-neutral-100">Core Skills</h3>
    <div class="mt-6 grid gap-6 sm:grid-cols-2">
      {skillGroups.map((group) => (
        <div class="rounded-lg border border-white/10 bg-white/[0.02] p-5">
          <p class="font-mono text-xs uppercase tracking-wide text-neutral-500">{group.label}</p>
          <ul class="mt-3 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-full border border-white/10 px-3 py-1 text-xs text-neutral-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Layout>
