---
import Layout from "../layouts/Layout.astro";
import HeroCanvas from "../components/HeroCanvas.astro";
import Stats from "../components/Stats.astro";
import { getCollection } from "astro:content";
import { site } from "../lib/site";

const allProjects = await getCollection("projects");
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const roles = [
  "fine-tune small LLMs",
  "build agentic systems",
  "design LLM evaluations",
  "ship production ML",
];

const skillGroups = [
  {
    label: "LLMs & Agentic Systems",
    items: [
      "LLM Fine-Tuning (SFT & RL)",
      "LangChain / LangGraph",
      "Agentic RAG & Tool Calling",
      "Multi-Agent Orchestration",
      "LLM-as-Judge Evaluation",
    ],
  },
  {
    label: "Search, Retrieval & Data",
    items: [
      "FAISS / Qdrant / Pinecone",
      "Hybrid Retrieval (BM25 + Embeddings)",
      "Re-ranking Models",
      "Golden Datasets & Offline Eval",
    ],
  },
  {
    label: "Backend & Infra",
    items: [
      "Python (FastAPI)",
      "Microservices",
      "Docker / Kubernetes",
      "Observability-First Design",
    ],
  },
  {
    label: "ML & DL",
    items: [
      "Supervised Learning & Embeddings",
      "Ranking / Learning-to-Rank",
      "Model Evaluation & Calibration",
      "Experimentation Frameworks",
    ],
  },
];
---

<Layout>
  <section class="relative overflow-hidden border-b border-white/10">
    <HeroCanvas />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-neutral-950/40 via-neutral-950/70 to-neutral-950"></div>

    <div class="relative mx-auto max-w-5xl px-6 pb-20 pt-24 sm:pt-32">
      <p data-reveal class="font-mono text-sm text-emerald-400">Hi, I'm</p>
      <h1 data-reveal style="--reveal-delay:80ms" class="mt-2 text-4xl font-bold tracking-tight text-neutral-50 sm:text-6xl">
        {site.name}
      </h1>
      <h2 data-reveal style="--reveal-delay:160ms" class="mt-4 text-xl text-neutral-300 sm:text-2xl">
        I <span id="typed-role" class="type-caret text-gradient font-semibold"></span>
      </h2>
      <p data-reveal style="--reveal-delay:240ms" class="mt-6 max-w-2xl text-base leading-relaxed text-neutral-400 sm:text-lg">
        I take messy, ambiguous problems and turn them into production-grade AI systems that
        ship, end to end: from data and evaluation design to fine-tuning, agent orchestration,
        and backend integration. Currently {site.currentRole.title} at {site.currentRole.company}.
      </p>

      <div data-reveal style="--reveal-delay:320ms" class="mt-8 flex flex-wrap gap-4">
        <a
          href="/projects"
          class="rounded-md bg-emerald-500 px-5 py-2.5 text-sm font-medium text-neutral-950 transition hover:bg-emerald-400 hover:shadow-lg hover:shadow-emerald-500/20"
        >
          View Projects
        </a>
        <a
          href="/contact"
          class="rounded-md border border-white/15 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:border-emerald-400/50 hover:text-emerald-300"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <Stats />

  <section class="mx-auto max-w-5xl px-6 py-14">
    <div data-reveal class="flex items-baseline justify-between">
      <h3 class="text-lg font-semibold text-neutral-100">Featured Work</h3>
      <a href="/projects" class="text-sm text-emerald-400 hover:text-emerald-300">All projects &rarr;</a>
    </div>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      {featured.map((project, i) => (
        <a
          href={`/projects/${project.id}`}
          data-reveal
          style={`--reveal-delay:${i * 100}ms`}
          class="glow-card group rounded-lg border border-white/10 bg-white/[0.02] p-5 transition duration-300 hover:-translate-y-1 hover:border-emerald-400/40"
        >
          <p class="font-mono text-xs uppercase tracking-wide text-emerald-400/80">{project.data.theme}</p>
          <h4 class="mt-2 text-sm font-semibold text-neutral-100 group-hover:text-emerald-300">
            {project.data.title}
          </h4>
          <p class="mt-2 text-sm leading-relaxed text-neutral-500 line-clamp-3">
            {project.data.summary}
          </p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-14">
    <h3 data-reveal class="text-lg font-semibold text-neutral-100">Core Skills</h3>
    <div class="mt-6 grid gap-6 sm:grid-cols-2">
      {skillGroups.map((group, i) => (
        <div
          data-reveal
          style={`--reveal-delay:${i * 90}ms`}
          class="glow-card rounded-lg border border-white/10 bg-white/[0.02] p-5"
        >
          <p class="font-mono text-xs uppercase tracking-wide text-neutral-500">{group.label}</p>
          <ul class="mt-3 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-full border border-white/10 px-3 py-1 text-xs text-neutral-300 transition hover:border-emerald-400/40 hover:text-emerald-300">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Layout>

<script define:vars={{ roles }}>
  const typeRoles = () => {
    const el = document.getElementById("typed-role");
    if (!el) return;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      el.textContent = roles[0];
      return;
    }

    let roleIdx = 0;
    let charIdx = 0;
    let deleting = false;

    const tick = () => {
      const current = roles[roleIdx];
      if (!deleting) {
        charIdx++;
        el.textContent = current.slice(0, charIdx);
        if (charIdx === current.length) {
          deleting = true;
          setTimeout(tick, 1600);
          return;
        }
        setTimeout(tick, 55);
      } else {
        charIdx--;
        el.textContent = current.slice(0, charIdx);
        if (charIdx === 0) {
          deleting = false;
          roleIdx = (roleIdx + 1) % roles.length;
          setTimeout(tick, 300);
          return;
        }
        setTimeout(tick, 30);
      }
    };
    tick();
  };

  typeRoles();
  document.addEventListener("astro:page-load", typeRoles);
</script>
